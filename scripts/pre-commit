#!/bin/bash
# secagent pre-commit hook
# Scans staged files for security issues before commit

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔍 secagent pre-commit scan..."
echo ""

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✓ No staged files to scan${NC}"
    exit 0
fi

# Create temporary directory for staged content
TMP_DIR=$(mktemp -d)
trap "rm -rf $TMP_DIR" EXIT

# Copy staged files to temp directory
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        mkdir -p "$TMP_DIR/$(dirname "$file")"
        git show ":$file" > "$TMP_DIR/$file" 2>/dev/null || true
    fi
done

# Run security scanners on staged files
FOUND_ISSUES=0

# Run gitleaks (secrets)
echo "Running gitleaks..."
if command -v gitleaks &> /dev/null; then
    GITLEAKS_OUTPUT=$(gitleaks detect --source "$TMP_DIR" --no-git 2>&1 || true)
    if [ -n "$GITLEAKS_OUTPUT" ] && echo "$GITLEAKS_OUTPUT" | grep -q "leaks found"; then
        echo -e "${RED}✗ Secrets detected:${NC}"
        echo "$GITLEAKS_OUTPUT" | grep -A5 "leaks found" || true
        FOUND_ISSUES=1
    else
        echo -e "${GREEN}✓ No secrets found${NC}"
    fi
fi

echo ""

# Run semgrep (code security) on code files
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(py|js|ts|go|java|rb|php)$' || true)
if [ -n "$CODE_FILES" ] && command -v semgrep &> /dev/null; then
    echo "Running semgrep..."
    SEMGREP_OUTPUT=$(semgrep --config auto --quiet $CODE_FILES 2>&1 || true)
    if [ -n "$SEMGREP_OUTPUT" ]; then
        echo -e "${YELLOW}⚠ Code issues found:${NC}"
        echo "$SEMGREP_OUTPUT" | head -50
        FOUND_ISSUES=1
    else
        echo -e "${GREEN}✓ No code issues found${NC}"
    fi
    echo ""
fi

# Summary
if [ $FOUND_ISSUES -eq 0 ]; then
    echo -e "${GREEN}✓ Pre-commit scan passed!${NC}"
    exit 0
else
    echo -e "${RED}✗ Pre-commit scan failed!${NC}"
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi
